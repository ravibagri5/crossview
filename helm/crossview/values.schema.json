{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Crossview Helm Chart Values",
  "description": "Configuration values for the Crossview Helm chart",
  "properties": {
    "global": {
      "type": "object",
      "properties": {
        "namespace": {
          "type": "string",
          "default": "crossview"
        },
        "createNamespace": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "default": "ghcr.io/crossplane-contrib/crossview"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"],
          "default": "Always"
        },
        "tag": {
          "type": "string",
          "default": ""
        },
        "platform": {
          "type": "string",
          "default": ""
        }
      }
    },
    "app": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "default": "crossview"
        },
        "port": {
          "type": "integer",
          "default": 3001
        },
        "replicas": {
          "type": "integer",
          "default": 1
        }
      }
    },
    "deployment": {
      "type": "object",
      "properties": {
        "strategy": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["RollingUpdate", "Recreate"],
              "default": "RollingUpdate"
            },
            "rollingUpdate": {
              "type": "object",
              "properties": {
                "maxSurge": { "type": ["string", "integer"], "default": 1 },
                "maxUnavailable": { "type": ["string", "integer"], "default": 0 }
              }
            }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "memory": { "type": "string", "default": "256Mi" },
            "cpu": { "type": "string", "default": "250m" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "memory": { "type": "string", "default": "1Gi" },
            "cpu": { "type": "string", "default": "1000m" }
          }
        }
      }
    },
    "healthCheck": {
      "type": "object",
      "properties": {
        "livenessProbe": { "type": "object" },
        "readinessProbe": { "type": "object" }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"],
          "default": "ClusterIP"
        },
        "port": { "type": "integer", "default": 80 },
        "targetPort": { "type": ["integer", "string"], "default": 3001 }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "className": { "type": "string", "default": "nginx" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      }
    },
    "database": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "default": "postgres" },
            "tag": { "type": "string", "default": "latest" }
          }
        },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "size": { "type": "string", "default": "10Gi" }
          }
        }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "ref": { "type": "string", "default": "" },
        "database": {
          "type": "object",
          "properties": {
            "host": { "type": "string", "default": "" },
            "port": { "type": "integer", "default": 5432 },
            "database": { "type": "string", "default": "crossview" },
            "username": { "type": "string", "default": "postgres" },
            "ssl": {
              "type": "object",
              "description": "PostgreSQL SSL/TLS connection settings",
              "properties": {
                "mode": {
                  "type": "string",
                  "default": "disable",
                  "enum": ["disable", "allow", "prefer", "require", "verify-ca", "verify-full"],
                  "description": "PostgreSQL SSL connection mode"
                },
                "rootCert": {
                  "type": "string",
                  "default": "",
                  "description": "Path to CA certificate file inside the container"
                },
                "cert": {
                  "type": "string",
                  "default": "",
                  "description": "Path to client certificate file inside the container"
                },
                "key": {
                  "type": "string",
                  "default": "",
                  "description": "Path to client private key file inside the container"
                }
              }
            }
          }
        },
        "server": {
          "type": "object",
          "properties": {
            "port": { "type": "integer", "default": 3001 },
            "auth": {
              "type": "object",
              "properties": {
                "mode": { "type": "string", "default": "session" }
              }
            }
          }
        },
        "sso": {
          "type": "object",
          "properties": {
            "oidc": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean", "default": true }
              }
            },
            "saml": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean", "default": true }
              }
            }
          }
        }
      }
    },
    "secrets": {
      "type": "object",
      "description": "Secret values. Plain string = chart creates secret. Object with secretKeyRef = reference existing secret.",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "properties": {
              "secretKeyRef": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "key": { "type": "string" }
                },
                "required": ["name", "key"]
              }
            },
            "required": ["secretKeyRef"]
          }
        ]
      },
      "examples": [
        {
          "adminUsername": "admin",
          "adminPassword": "super-secret",
          "dbPassword": "db-pass-123"
        },
        {
          "dbPassword": {
            "secretKeyRef": {
              "name": "prod-db-secrets",
              "key": "password"
            }
          }
        }
      ]
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean", "default": true },
        "name": { "type": "string", "default": "crossview-sa" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean", "default": true }
      }
    },
    "affinity": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" }
  }
}
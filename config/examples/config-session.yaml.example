database:
  enabled: true
  host: localhost
  port: 8920
  database: crossview
  username: postgres
  password: password

server:
  admin:
    username: admin
    password: password
  port: 3001
  auth:
    mode: "session"
  log:
    level: info
  cors:
    origin: http://localhost:3001
    credentials: true
  session:
    secret: crossview-secret-key-change-in-production
    cookie:
      secure: false
      httpOnly: true
      maxAge: 86400000

sso:
  enabled: false
    
vite:
  server:
    proxy:
      api:
        target: http://localhost:3001
        changeOrigin: true

